  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shihangbin/vitepress-notes/issues"
  },
  "homepage": "https://github.com/shihangbin/vitepress-notes#readme",
  "devDependencies": {
    "@femm/prettier": "^1.1.0",
    "@femm/tailwind-config": "^1.0.0",
    "@femm/verify-commit": "^1.0.1",
    "@giscus/vue": "^3.1.1",
    "@mdit-vue/shared": "^3.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "medium-zoom": "^1.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "sass": "^1.93.2",
    "tailwindcss": "^4.2.2",
    "vite-plugin-markdown-preview": "^1.1.1",
    "vitepress": "^1.6.4",
    "vitepress-sidebar": "^1.33.1",
    "vue": "^3.5.22"
